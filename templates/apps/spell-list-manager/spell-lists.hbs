<div class="spell-lists-sidebar" role="complementary">
  {{#if (eq sidebarMode "filters")}}
    <div class="sidebar-filter-header">
      <h2>{{localize "SPELLMANAGER.Sidebar.AvailableSpells"}}</h2>
      <button type="button" class="header-action-btn" data-action="switchSidebarMode" data-mode="lists">
        <i class="fas fa-arrow-left" aria-hidden="true"></i>
        {{localize "SPELLMANAGER.Sidebar.BackToLists"}}
      </button>
    </div>
    <div class="sidebar-filter-section">
      {{#if filterFormElements}}
        <div class="filter-search">
          {{> "modules/spell-book/templates/components/filter-item.hbs" filterFormElements.search}}
        </div>
        <div class="filter-list">
          {{> "modules/spell-book/templates/components/filter-item.hbs" filterFormElements.level}}
          {{> "modules/spell-book/templates/components/filter-item.hbs" filterFormElements.school}}
          {{> "modules/spell-book/templates/components/filter-item.hbs" filterFormElements.castingTime}}
          {{> "modules/spell-book/templates/components/filter-item.hbs" filterFormElements.damageType}}
          {{> "modules/spell-book/templates/components/filter-item.hbs" filterFormElements.condition}}
          {{> "modules/spell-book/templates/components/filter-item.hbs" filterFormElements.requiresSave}}
          {{> "modules/spell-book/templates/components/filter-item.hbs" filterFormElements.concentration}}
          {{> "modules/spell-book/templates/components/filter-item.hbs" filterFormElements.materialComponents}}
        </div>
        <div class="filter-range">
          <label>{{localize 'DND5E.Range'}}
            ({{#if settings.useMetricUnits}}{{localize 'DND5E.DistM'}}{{else}}{{localize 'DND5E.DistFt'}}{{/if}})</label>
          <div class="range-inputs">
            {{> "modules/spell-book/templates/components/filter-item.hbs" filterFormElements.minRange}}
            {{> "modules/spell-book/templates/components/filter-item.hbs" filterFormElements.maxRange}}
          </div>
        </div>
        <div class="filter-source">
          {{> "modules/spell-book/templates/components/filter-item.hbs" filterFormElements.compendiumSource}}
          {{> "modules/spell-book/templates/components/filter-item.hbs" filterFormElements.spellSource}}
        </div>
        <div class="filter-checkbox">
          {{> "modules/spell-book/templates/components/filter-item.hbs" filterFormElements.ritual}}
        </div>
        <button type="button" class="reset-filters" data-tooltip="{{localize 'SPELLMANAGER.Filters.Reset'}}">
          <i class="fas fa-rotate-left" aria-hidden="true"></i> {{localize "SPELLMANAGER.Filters.Reset"}}
        </button>
      {{/if}}
    </div>
  {{else}}
    <div class="lists-header">
      <h2>{{localize 'SPELLMANAGER.Columns.SpellLists'}}</h2>
      <div class="lists-header-actions">
        <button type="button" class="header-action-btn" data-action="createList"
          data-tooltip="{{localize 'SPELLMANAGER.Tooltips.CreateNew'}}">
          <i class="fas fa-plus" aria-hidden="true"></i> {{localize "SPELLMANAGER.Buttons.CreateNew"}}
        </button>
        <button type="button" class="header-action-btn" data-action="mergeLists"
          data-tooltip="{{localize 'SPELLMANAGER.Tooltips.MergeLists'}}">
          <i class="fas fa-code-merge" aria-hidden="true"></i> {{localize "SPELLMANAGER.Buttons.MergeLists"}}
        </button>
      </div>
    </div>
    <div class="lists-container" role="list">
      {{#if hasActorOwnedLists}}
        {{#> "modules/spell-book/templates/components/folder-section.hbs"
          folderType="actor-lists" folderId="actor-lists" icon="fas fa-user"
          folderHeader=(localize "SPELLMANAGER.Folders.PlayerSpellbooks")
          folderTooltip=(localize "SPELLMANAGER.Tooltips.PlayerSpellbooksFolder")}}
          {{#each actorOwnedLists as |list|}}
            <li class="spell-list-item actor-owned-list" data-uuid="{{list.uuid}}" role="listitem" data-tooltip-direction="RIGHT" data-tooltip-html="<div style='text-align:center;'><strong>{{list.name}}</strong><hr>{{list.pack}}<br>{{localize 'SPELLMANAGER.ListTooltip.SpellCount' count=list.spellCount}}</div>">
              <div class="list-item-header">
                <div class="list-item-content" data-action="selectList" data-uuid="{{list.uuid}}">
                  <div class="list-name">
                    <i class="{{list.icon}}" aria-hidden="true"></i>
                    <span>{{list.name}}</span>
                  </div>
                </div>
              </div>
            </li>
          {{/each}}
        {{/"modules/spell-book/templates/components/folder-section.hbs"}}
      {{/if}}
      {{#if hasCustomLists}}
        {{#> "modules/spell-book/templates/components/folder-section.hbs"
          folderType="custom-lists" folderId="custom-lists" icon="fas fa-magic"
          folderHeader=(localize "SPELLMANAGER.Folders.CustomLists")
          folderTooltip=(localize "SPELLMANAGER.Tooltips.CustomListsFolder")}}
          {{#each customLists as |list|}}
            <li class="spell-list-item custom-list" data-uuid="{{list.uuid}}" role="listitem" data-tooltip-direction="RIGHT" data-tooltip-html="<div style='text-align:center;'><strong>{{list.name}}</strong><hr>{{list.pack}}<br>{{localize 'SPELLMANAGER.ListTooltip.SpellCount' count=list.spellCount}}</div>">
              <div class="list-item-header">
                <div class="list-item-content" data-action="selectList" data-uuid="{{list.uuid}}">
                  <div class="list-name">
                    <i class="{{list.icon}} is-custom-list" aria-hidden="true"></i>
                    <span>{{list.name}}</span>
                  </div>
                </div>
                <button type="button" class="visibility-toggle" data-action="hideList" data-uuid="{{list.uuid}}"
                  data-tooltip="{{localize 'SPELLMANAGER.HideList.HideTooltip'}}">
                  <i class="fas fa-eye" aria-hidden="true"></i>
                </button>
              </div>
            </li>
          {{/each}}
        {{/"modules/spell-book/templates/components/folder-section.hbs"}}
      {{/if}}
      {{#if hasMergedLists}}
        {{#> "modules/spell-book/templates/components/folder-section.hbs"
          folderType="merged-lists" folderId="merged-lists" icon="fas fa-code-merge"
          folderHeader=(localize "SPELLMANAGER.Folders.MergedLists")
          folderTooltip=(localize "SPELLMANAGER.Tooltips.MergedListsFolder")}}
          {{#each mergedLists as |list|}}
            <li class="spell-list-item merged-list" data-uuid="{{list.uuid}}" role="listitem" data-tooltip-direction="RIGHT" data-tooltip-html="<div style='text-align:center;'><strong>{{list.name}}</strong><hr>{{list.pack}}<br>{{localize 'SPELLMANAGER.ListTooltip.SpellCount' count=list.spellCount}}</div>">
              <div class="list-item-header">
                <div class="list-item-content" data-action="selectList" data-uuid="{{list.uuid}}">
                  <div class="list-name">
                    <i class="{{list.icon}} is-merged-list" aria-hidden="true"></i>
                    <span>{{list.name}}</span>
                  </div>
                </div>
                <button type="button" class="visibility-toggle" data-action="hideList" data-uuid="{{list.uuid}}"
                  data-tooltip="{{localize 'SPELLMANAGER.HideList.HideTooltip'}}">
                  <i class="fas fa-eye" aria-hidden="true"></i>
                </button>
              </div>
            </li>
          {{/each}}
        {{/"modules/spell-book/templates/components/folder-section.hbs"}}
      {{/if}}
      {{#if hasModifiedLists}}
        {{#> "modules/spell-book/templates/components/folder-section.hbs"
          folderType="modified-lists" folderId="modified-lists" icon="fas fa-pen"
          folderHeader=(localize "SPELLMANAGER.Folders.ModifiedLists")
          folderTooltip=(localize "SPELLMANAGER.Tooltips.ModifiedListsFolder")}}
          {{#each modifiedLists as |list|}}
            <li class="spell-list-item modified-list" data-uuid="{{list.uuid}}" role="listitem" data-tooltip-direction="RIGHT" data-tooltip-html="<div style='text-align:center;'><strong>{{list.name}}</strong><hr>{{list.pack}}<br>{{localize 'SPELLMANAGER.ListTooltip.SpellCount' count=list.spellCount}}</div>">
              <div class="list-item-header">
                <div class="list-item-content" data-action="selectList" data-uuid="{{list.uuid}}">
                  <div class="list-name">
                    <i class="{{list.icon}} is-modified-list" aria-hidden="true"></i>
                    <span>{{list.name}}</span>
                  </div>
                </div>
                <button type="button" class="visibility-toggle" data-action="hideList" data-uuid="{{list.uuid}}"
                  data-tooltip="{{localize 'SPELLMANAGER.HideList.HideTooltip'}}">
                  <i class="fas fa-eye" aria-hidden="true"></i>
                </button>
              </div>
            </li>
          {{/each}}
        {{/"modules/spell-book/templates/components/folder-section.hbs"}}
      {{/if}}
      {{#if hasStandardLists}}
        {{#> "modules/spell-book/templates/components/folder-section.hbs"
          folderType="standard-lists" folderId="standard-lists" icon="fas fa-scroll"
          folderHeader=(localize "SPELLMANAGER.Folders.SpellLists")
          folderTooltip=(localize "SPELLMANAGER.Tooltips.StandardListsFolder")}}
          {{#each standardLists as |list|}}
            <li class="spell-list-item" data-uuid="{{list.uuid}}" role="listitem" data-tooltip-direction="RIGHT" data-tooltip-html="<div style='text-align:center;'><strong>{{list.name}}</strong><hr>{{list.pack}}<br>{{localize 'SPELLMANAGER.ListTooltip.SpellCount' count=list.spellCount}}</div>">
              <div class="list-item-header">
                <div class="list-item-content" data-action="selectList" data-uuid="{{list.uuid}}">
                  <div class="list-name">
                    <i class="{{list.icon}}" aria-hidden="true"></i>
                    <span>{{list.name}}</span>
                  </div>
                </div>
                <button type="button" class="visibility-toggle" data-action="hideList" data-uuid="{{list.uuid}}"
                  data-tooltip="{{localize 'SPELLMANAGER.HideList.HideTooltip'}}">
                  <i class="fas fa-eye" aria-hidden="true"></i>
                </button>
              </div>
            </li>
          {{/each}}
        {{/"modules/spell-book/templates/components/folder-section.hbs"}}
      {{/if}}
      {{#if hasHiddenLists}}
        {{#> "modules/spell-book/templates/components/folder-section.hbs"
          folderType="hidden-lists" folderId="hidden-lists" icon="fas fa-eye-slash"
          folderHeader=(localize "SPELLMANAGER.Folders.HiddenLists")
          folderTooltip=(localize "SPELLMANAGER.Tooltips.HiddenListsFolder")}}
          {{#each hiddenSpellLists as |list|}}
            <li class="spell-list-item hidden-list" data-uuid="{{list.uuid}}" role="listitem" data-tooltip-direction="RIGHT" data-tooltip-html="<div style='text-align:center;'><strong>{{list.name}}</strong><hr>{{list.pack}}<br>{{localize 'SPELLMANAGER.ListTooltip.SpellCount' count=list.spellCount}}</div>">
              <div class="list-item-header">
                <div class="list-item-content" data-action="selectList" data-uuid="{{list.uuid}}">
                  <div class="list-name">
                    <i class="{{list.icon}}" aria-hidden="true"></i>
                    <span>{{list.name}}</span>
                  </div>
                </div>
                <button type="button" class="visibility-toggle" data-action="hideList" data-uuid="{{list.uuid}}"
                  data-tooltip="{{localize 'SPELLMANAGER.HideList.UnhideTooltip'}}">
                  <i class="fas fa-eye-slash" aria-hidden="true"></i>
                </button>
              </div>
            </li>
          {{/each}}
        {{/"modules/spell-book/templates/components/folder-section.hbs"}}
      {{/if}}
      {{#unless availableSpellLists.length}}
        {{> "modules/spell-book/templates/components/empty-state.hbs" message=(localize "SPELLMANAGER.Columns.NoLists")}}
      {{/unless}}
    </div>
  {{/if}}
</div>
