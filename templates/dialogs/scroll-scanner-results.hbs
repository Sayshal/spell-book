<div class="scroll-scanner">
	<p>{{{localize 'SPELLBOOK.ScrollProcessor.ResultsHeader' count=scrolls.length}}}</p>
	<div>
		<table>
			<thead>
				<tr>
					<th>{{localize 'SPELLBOOK.ScrollProcessor.TableHeaderName'}}</th>
					<th>{{localize 'SPELLBOOK.ScrollProcessor.TableHeaderUUID'}}</th>
				</tr>
			</thead>
			<tbody>
				{{#each scrolls}}
					<tr>
						<td>{{this.name}}</td>
						<td>{{this.uuid}}</td>
					</tr>
				{{/each}}
			</tbody>
		</table>
	</div>
	<p><em>{{localize 'SPELLBOOK.ScrollProcessor.ResultsFooter'}}</em></p>
</div>
