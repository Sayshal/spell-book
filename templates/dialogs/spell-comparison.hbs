<div class="spell-comparison-content">
  <header class="comparison-drag-handle">
    <span class="comparison-title">
      <i class="fas fa-scale-balanced" aria-hidden="true"></i>
      {{localize "SPELLBOOK.Comparison.DialogTitle"}}
    </span>
    <button type="button" class="comparison-detach" data-action="toggleDetach"
      data-tooltip="{{#if detached}}{{localize 'APPLICATION.ACTIONS.Attach'}}{{else}}{{localize 'APPLICATION.ACTIONS.Detach'}}{{/if}}"
      aria-label="{{#if detached}}{{localize 'APPLICATION.ACTIONS.Attach'}}{{else}}{{localize 'APPLICATION.ACTIONS.Detach'}}{{/if}}">
      <i class="fas {{#if detached}}fa-arrow-down-to-square{{else}}fa-arrow-up-right-from-square{{/if}}" aria-hidden="true"></i>
    </button>
    <button type="button" class="comparison-close" data-action="close"
      data-tooltip="{{localize 'Close'}}" aria-label="{{localize 'Close'}}">
      <i class="fas fa-xmark" aria-hidden="true"></i>
    </button>
  </header>
  {{#if spells.length}}
    <table class="comparison-table">
      <thead>
        <tr>
          <th class="corner"></th>
          {{#each spells}}
            <th class="spell-header" scope="col">
              <div class="spell-info">
                {{{enrichedIcon}}}
                <span class="spell-name">{{name}}</span>
              </div>
            </th>
          {{/each}}
        </tr>
      </thead>
      <tbody>
        {{#each comparisonData.properties}}
          <tr data-key="{{key}}">
            <th class="property-name" scope="row">{{name}}</th>
            {{#each values}}
              <td class="property-value{{#if highlight}} highlighted{{/if}}">{{value}}</td>
            {{/each}}
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <div class="empty-comparison">
      <p>{{localize "SPELLBOOK.Comparison.NoSpellsSelected"}}</p>
    </div>
  {{/if}}
</div>
